# backend/.env — LOCAL DEVELOPMENT ONLY
# This file is git-ignored. Never commit it.
#
# Copy for local dev:  cp .env.example .env
# Then fill in values below.
#
# For production (Render/Railway), set these as environment variables
# in your platform dashboard — do NOT use this file in production.

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-50-char-random-secret-key-here

# True = local dev mode (SQLite fallback, insecure key warning allowed)
# NEVER set True in production
DEBUG=True

# Comma-separated. In production: your-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank locally to use SQLite.
# In production: provided by Render/Railway/Supabase PostgreSQL add-on.
# DATABASE_URL=postgres://user:password@host:5432/tilla_db

# Frontend origin(s) that can call the API.
# In production: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Keep False on Railway/Render/Fly.io (proxy terminates TLS).
# See settings.py HTTPS section for full explanation.
SECURE_SSL_REDIRECT=False
